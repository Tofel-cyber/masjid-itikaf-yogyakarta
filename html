// Load dari localStorage jika ada
function loadData() {
  try {
    const saved = localStorage.getItem('masjid_itikaf_data');
    if (saved) {
      const parsed = JSON.parse(saved);
      if (parsed && parsed.length >= 3) mosques = parsed;
    }
  } catch(e) {}
}
 
function saveData() {
  try { localStorage.setItem('masjid_itikaf_data', JSON.stringify(mosques)); } catch(e) {}
}
 
// ═══════════════════════════════════════
// RENDER
// ═══════════════════════════════════════
function renderList() {
  const q = document.getElementById('search-input').value.toLowerCase().trim();
  const filtered = mosques.filter(m =>
    m.name.toLowerCase().includes(q) ||
    m.area.toLowerCase().includes(q) ||
    m.address.toLowerCase().includes(q)
  );
 
  const container = document.getElementById('mosques-list');
  if (filtered.length === 0) {
    container.innerHTML = `<div class="empty-state"><div style="font-size:40px;">🔍</div><p>Tidak ada masjid yang ditemukan.<br>Coba kata kunci lain.</p></div>`;
    return;
  }
 
  container.innerHTML = filtered.map(m => `
    <div class="mosque-card ${m.isNew ? 'is-new' : ''}" onclick="openDetail(${m.id})">
      ${m.isNew ? '<span class="new-badge">✦ Baru</span>' : ''}
      <div class="mosque-name">${m.name}</div>
      <div class="mosque-area">📍 ${m.area}</div>
      <div class="rating-row">
        <span class="stars">${'★'.repeat(Math.round(m.rating))}</span>
        <span class="rating-num">${m.rating > 0 ? m.rating.toFixed(1) : '—'}</span>
        <span style="color:var(--gray-200)">·</span>
        <span class="status-dot"></span>
        <span class="status-text">Tersedia</span>
      </div>
      <div class="tags-row">
        ${m.tags.map(t => `<span class="tag tag-green">${t}</span>`).join('')}
        ${m.capacity ? `<span class="tag tag-blue">👥 ${m.capacity} orang</span>` : ''}
      </div>
      <div class="card-actions">
        ${m.phone
          ? `<a href="https://wa.me/${m.phone.replace(/[^0-9]/g,'')}" class="btn-wa whatsapp" onclick="event.stopPropagation()">
               <svg width="15" height="15" viewBox="0 0 24 24" fill="currentColor"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347z"/><path d="M12 0C5.373 0 0 5.373 0 12c0 2.025.507 3.934 1.399 5.61L.057 23.882a.75.75 0 0 0 .921.94l6.453-1.688A11.945 11.945 0 0 0 12 24c6.627 0 12-5.373 12-12S18.627 0 12 0zm0 22c-1.885 0-3.652-.497-5.183-1.368l-.371-.214-3.861 1.011 1.031-3.762-.23-.384A9.955 9.955 0 0 1 2 12C2 6.477 6.477 2 12 2s10 4.477 10 10-4.477 10-10 10z"/></svg>
               WhatsApp Takmir
             </a>`
          : `<span class="btn-wa no-contact">Hubungi via kunjungan</span>`
