function closeDetail(e) {
  if (e.target === document.getElementById('detail-overlay')) closeDetailBtn();
}
function closeDetailBtn() {
  document.getElementById('detail-overlay').classList.remove('open');
  document.getElementById('d-map').src = '';
  document.body.style.overflow = '';
}
 
// ═══════════════════════════════════════
// ADD FORM
// ═══════════════════════════════════════
function openAddForm() {
  document.getElementById('add-modal').classList.add('open');
  document.body.style.overflow = 'hidden';
}
function closeAddModal(e) {
  if (e.target === document.getElementById('add-modal')) closeAddForm();
}
function closeAddForm() {
  document.getElementById('add-modal').classList.remove('open');
  document.body.style.overflow = '';
}
 
function addMosque() {
  const name = document.getElementById('f-name').value.trim();
  const takmir = document.getElementById('f-takmir').value.trim();
  const phone = document.getElementById('f-phone').value.trim();
  const address = document.getElementById('f-address').value.trim();
  const capacity = document.getElementById('f-capacity').value.trim();
  const maps = document.getElementById('f-maps').value.trim();
  const facilities = document.getElementById('f-facilities').value.trim();
  const notes = document.getElementById('f-notes').value.trim();
 
  if (!name || !address) {
    showToast('⚠️ Nama masjid dan alamat wajib diisi');
    return;
  }
 
  const newId = mosques.length > 0 ? Math.max(...mosques.map(m => m.id)) + 1 : 1;
  const phoneClean = phone.replace(/^0/, '62');
 
  mosques.push({
    id: newId,
    name,
    area: address.split(',').slice(-2).join(',').trim(),
    address,
    takmir: takmir || 'Belum tercatat',
    phone: phone || null,
    capacity: capacity || null,
    facilities: facilities ? facilities.split(',').map(f => f.trim()).filter(Boolean) : [],
    notes: notes || '',
    rating: 0,
    mapsUrl: maps || `https://maps.google.com/?q=${encodeURIComponent(name + ' ' + address)}`,
    embedUrl: maps
      ? maps.replace('google.com/maps/', 'google.com/maps/embed/').split('?')[0]
      : `https://www.google.com/maps/embed?pb=!1m2!1d-7.79!2d110.35`,
    isNew: true,
    tags: [takmir ? takmir : 'Baru ditambahkan']
  });
 
  saveData();
  ['f-name','f-takmir','f-phone','f-address','f-capacity','f-maps','f-facilities','f-notes']
    .forEach(id => { document.getElementById(id).value = ''; });
  closeAddForm();
  renderList();
  showToast('✅ Masjid berhasil ditambahkan!');
}
 
function showToast(msg) {
  const t = document.getElementById('toast');
  t.textContent = msg;
  t.classList.add('show');
  setTimeout(() => t.classList.remove('show'), 3000);
}
 
// ═══════════════════════════════════════
// INIT
// ═══════════════════════════════════════
loadData();
renderList();
</script>
