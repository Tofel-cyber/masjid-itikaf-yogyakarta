function updateStats() {
  const total = mosques.length;
  document.getElementById('stat-total').textContent = total;
  document.getElementById('stat-active').textContent = total;
  document.getElementById('header-badge').textContent = total + ' Masjid';
}
 
function filterMosques() { renderList(); }
 
// ═══════════════════════════════════════
// TABS
// ═══════════════════════════════════════
function switchTab(tab, el) {
  document.querySelectorAll('.tab').forEach(t => t.classList.remove('active'));
  el.classList.add('active');
  document.getElementById('tab-list').style.display = tab === 'list' ? 'block' : 'none';
  document.getElementById('tab-map').style.display = tab === 'map' ? 'block' : 'none';
}
 
// ═══════════════════════════════════════
// DETAIL SHEET
// ═══════════════════════════════════════
